# VietLaw-Chat MVP local environment example
# Copy values into a local .env file when running the backend.
# Do not commit real API keys or secrets.

APP_ENV=development
LOG_LEVEL=info
BACKEND_MODE=lite

# Provider-neutral AI config. Backend config may map this to a concrete provider.
AI_API_KEY=your_api_key_here
AI_MODEL_NAME=api-model
AI_BASE_URL=

# Runtime paths
CHAT_DB_PATH=./data/vietlaw_chat.sqlite3
LEGAL_SNIPPETS_PATH=./data/legal_snippets.json
UNSAFE_PATTERNS_PATH=./data/unsafe_patterns.json

# CORS/demo settings
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ---------------------------------------------------------------------------
# Evaluation (evaluation/, scripts/run_eval_full.py)
#
# The evaluation system talks to a backend only over HTTP and needs no secrets.
# These are convenience defaults; every one can be passed on the command line.
# ---------------------------------------------------------------------------

# Targets. Production is the teammate's backend/, reference is backend_lite/.
EVAL_PRODUCTION_URL=http://127.0.0.1:8000
EVAL_REFERENCE_URL=http://127.0.0.1:8010

# Fixed seed so generated (metamorphic) cases are reproducible across runs.
EVAL_SEED=20260713
EVAL_REPORT_DIR=outputs/eval

# Use a throwaway DB for evaluation so runs never touch demo chat history.
EVAL_CHAT_DB_PATH=/tmp/vietlaw_eval.sqlite3

# Optional LLM-as-judge. OFF by default and never required: the core suites must
# run with no network access beyond the backend under test. If you enable it, the
# judge can only add a human-review flag — it can never turn a deterministic
# failure into a pass, and it is never the sole reason a case fails.
# EVAL_LLM_JUDGE=0
# ANTHROPIC_API_KEY=your_api_key_here
